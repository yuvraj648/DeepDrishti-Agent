# API: use relative path in dev so Vite proxy sends /api/* to the backend (vite.config.js)
VITE_API_URL=/api/v1
# Optional: if your Node API runs on another host/port, set for dev proxy only:
# VITE_DEV_API_ORIGIN=http://127.0.0.1:5003

# Development Settings
VITE_NODE_ENV=development

# App Configuration
VITE_APP_NAME=Deep-Drishti Marine Surveillance
VITE_APP_VERSION=1.0.0
